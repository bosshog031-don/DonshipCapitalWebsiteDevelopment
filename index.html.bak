    <div class="stat-item">
      <div class="stat-num">$7,997</div>
      <div class="stat-label">Full AI-powered business<br>infrastructure — Scale package</div>
    </div>
  </div>
</div>

<!-- AI OPS SPLIT -->
<div class="split">
  <div class="split-panel dark">
    <div class="eyebrow">AI Operating System</div>
    <h2 class="display-md" style="color:var(--white);margin-bottom:20px">The Donship AI Operating System</h2>
    <p style="color:var(--muted-dark);line-height:1.75;margin-bottom:36px;max-width:480px">We don't sell you software — we install an AI workforce. Our proprietary system answers your calls, qualifies your leads, and runs your operations around the clock.</p>
    <a href="/book.html" class="btn btn-green btn-arrow">Get AI Ops built for you</a>
  </div>
  <div class="split-panel dark-2">
    <div class="ai-stack">
      <div class="ai-stack-item">
        <div>
          <div class="ai-name">VoiceDesk</div>
          <div class="ai-desc">AI receptionist answering every call 24/7, booking appointments, qualifying callers.</div>
        </div>
        <div class="ai-arrow">→</div>
      </div>
      <div class="ai-stack-item">
        <div>
          <div class="ai-name">LeadCatch</div>
          <div class="ai-desc">Always-on AI chat across your site, WhatsApp, and SMS — capturing and routing every lead.</div>
        </div>
        <div class="ai-arrow">→</div>
      </div>
      <div class="ai-stack-item">
        <div>
          <div class="ai-name">PocketOps</div>
          <div class="ai-desc">24/7 AI operations agent on your phone — scheduling, follow-ups, busywork while you sleep.</div>
        </div>
        <div class="ai-arrow">→</div>
      </div>
      <div class="ai-stack-item">
        <div>
          <div class="ai-name">FlowEngine</div>
          <div class="ai-desc">Automation layer connecting your store, CRM, and tools so data moves itself.</div>
        </div>
        <div class="ai-arrow">→</div>
      </div>
    </div>
  </div>
</div>

<!-- PACKAGES -->
<section class="section section-light" id="packages">
