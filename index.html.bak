    </div>
  </div>
</div>

<!-- FIVE PILLARS -->
<section class="section section-light">
  <div class="container">
    <div class="section-intro" data-anim>
      <div>
        <div class="eyebrow eyebrow-light">What we build</div>
        <h2 class="display-md">Five pillars. One engagement.</h2>
      </div>
      <div class="section-intro-cta">
        <p style="color:var(--muted-light);max-width:340px;margin-bottom:20px">We don't consult — we build. Every engagement covers all the infrastructure your business needs to operate and grow.</p>
        <a href="/services.html" class="btn btn-outline-dark btn-arrow">View all services</a>
      </div>
    </div>
    <div class="row-list" data-anim>
      <div class="row-item three-col">
        <span class="row-num">01</span>
        <span class="row-title">Fund</span>
        <span class="row-desc">Business credit + funding strategy</span>
      </div>
      <div class="row-item three-col">
        <span class="row-num">02</span>
        <span class="row-title">Build</span>
        <span class="row-desc">E-commerce stores + payments</span>
      </div>
      <div class="row-item three-col">
        <span class="row-num">03</span>
        <span class="row-title">Market</span>
        <span class="row-desc">Content, ads + lead generation</span>
      </div>
      <div class="row-item three-col">
        <span class="row-num">04</span>
        <span class="row-title">Automate</span>
        <span class="row-desc">CRM, workflows + operations</span>
      </div>
      <div class="row-item three-col">
        <span class="row-num">05</span>
        <span class="row-title">AI Ops</span>
        <span class="row-desc">Voice, chat + mobile agents</span>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
