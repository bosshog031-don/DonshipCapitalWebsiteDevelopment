        <span class="hero-badge">Credit + Funding</span>
        <span class="hero-badge">E-Commerce</span>
        <span class="hero-badge">Marketing</span>
        <span class="hero-badge">AI Ops</span>
      </div>
    </div>
  </div>
  <div class="scroll-down-indicator">
    <a href="#packages" aria-label="Scroll down">
      <span class="scroll-mouse">
        <span class="scroll-wheel"></span>
      </span>
    </a>
  </div>
</section>

<!-- MARQUEE -->
