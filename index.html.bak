  <div class="marquee-strip">
    <div class="marquee-track">
      <div class="marquee-item">FUND <span>·</span></div>
      <div class="marquee-item">BUILD <span>·</span></div>
      <div class="marquee-item">MARKET <span>·</span></div>
      <div class="marquee-item">AUTOMATE <span>·</span></div>
      <div class="marquee-item">AI OPS <span>·</span></div>
