<!-- HERO -->
<section class="hero">
  <canvas class="hero-canvas" id="hero-canvas"></canvas>
  <div class="hero-grid" style="position: relative; z-index: 2;">
    <div class="hero-left">
      <div class="eyebrow">Infrastructure for founders</div>
      <h1 class="hero-h1">We help you <span class="hero-cycle-wrap"><span class="hero-cycle-word active" id="hero-cycle-word">Fund</span></span><br>your business.</h1>
      <p class="hero-sub">Business credit, funding strategy, store buildouts, marketing systems, and AI-powered operations — built and managed for you, end to end.</p>
      <div class="hero-actions">
        <a href="/book.html" class="btn btn-green btn-lg btn-arrow btn-primary-pulse">Book a free call</a>
        <a href="/services.html" class="btn btn-outline-white btn-lg">View packages</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-stat-box">
        <div class="hero-stat-num">2–4<span>wk</span></div>
        <div class="hero-stat-label">Average time from discovery call to launch</div>
      </div>
      <div class="hero-stat-box">
        <div class="hero-stat-num"><span>$</span>1,497</div>
        <div class="hero-stat-label">Starting from — credit + web presence</div>
      </div>
