    <div class="stat-item">
      <div class="stat-num">2–4 <span>Wks</span></div>
      <div class="stat-label">Average time from discovery<br>call to fully launched</div>
    </div>
    <div class="stat-item">
      <div class="stat-num"><span>4</span> AI Tools</div>
      <div class="stat-label">VoiceDesk, LeadCatch,<br>PocketOps &amp; FlowEngine</div>
