        <a href="/book.html" class="btn pkg-cta" style="background:var(--white);color:var(--green);border:1.5px solid var(--white);display:block;width:100%;text-align:center;padding:14px 28px;font-size:0.875rem;font-weight:600;border-radius:2px;margin-top:8px">Book a call</a>
      </div>
      <div class="pkg-card">
        <div class="pkg-name">Scale</div>
        <div class="pkg-price">$7,997</div>
        <div class="pkg-target">Full AI-powered business infrastructure</div>
        <ul class="pkg-features">
          <li class="pkg-feature"><span class="pkg-check">✓</span>Everything in Growth</li>
